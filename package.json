{
  "name": "coupang-cli",
  "version": "1.1.0",
  "description": "Private Coupang shopping automation CLI for Linux, macOS, and OpenClaw",
  "type": "module",
  "bin": {
    "cpcli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "skills",
    "scripts/cpcli-launcher.mjs",
    "scripts/openclaw-smoke.mjs",
    "scripts/wait-keypad-ready.mjs",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "postinstall": "npx playwright install chromium || true",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "coupang",
    "쿠팡",
    "cli",
    "playwright",
    "shopping",
    "automation",
    "쇼핑",
    "자동화"
  ],
  "author": "kochangbok",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kochangbok/coupang-skill-linux.git"
  },
  "homepage": "https://github.com/kochangbok/coupang-skill-linux",
  "bugs": {
    "url": "https://github.com/kochangbok/coupang-skill-linux/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "inquirer": "^12.4.0",
    "ora": "^8.2.0",
    "playwright": "^1.50.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
